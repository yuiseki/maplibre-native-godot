[configuration]

entry_symbol = "maplibre_native_godot_library_init"
compatibility_minimum = "4.3"
reloadable = true

[libraries]

linux.debug.x86_64 = "res://bin/libmaplibre_native_godot.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://bin/libmaplibre_native_godot.linux.template_release.x86_64.so"
