[configuration]

entry_symbol = "maplibre_native_godot_library_init"
compatibility_minimum = "4.3"
reloadable = true

[libraries]

linux.debug.x86_64   = "res://addons/maplibre_native_godot/bin/libmaplibre_native_godot.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/maplibre_native_godot/bin/libmaplibre_native_godot.linux.template_release.x86_64.so"

windows.debug.x86_64   = "res://addons/maplibre_native_godot/bin/maplibre_native_godot.windows.template_release.x86_64.dll"
windows.release.x86_64 = "res://addons/maplibre_native_godot/bin/maplibre_native_godot.windows.template_release.x86_64.dll"

macos.debug             = "res://addons/maplibre_native_godot/bin/libmaplibre_native_godot.macos.template_debug.arm64.dylib"
macos.debug.arm64       = "res://addons/maplibre_native_godot/bin/libmaplibre_native_godot.macos.template_debug.arm64.dylib"
macos.debug.universal   = "res://addons/maplibre_native_godot/bin/libmaplibre_native_godot.macos.template_debug.arm64.dylib"
macos.release           = "res://addons/maplibre_native_godot/bin/libmaplibre_native_godot.macos.template_release.arm64.dylib"
macos.release.arm64     = "res://addons/maplibre_native_godot/bin/libmaplibre_native_godot.macos.template_release.arm64.dylib"
macos.release.universal = "res://addons/maplibre_native_godot/bin/libmaplibre_native_godot.macos.template_release.arm64.dylib"

[dependencies]

windows.debug.x86_64 = {
    "res://addons/maplibre_native_godot/bin/wgpu_native.dll" : ""
}
windows.release.x86_64 = {
    "res://addons/maplibre_native_godot/bin/wgpu_native.dll" : ""
}
